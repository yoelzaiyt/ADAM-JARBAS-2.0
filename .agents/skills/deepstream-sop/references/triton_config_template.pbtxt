name: "ddm"
backend: "python"
# platform: "tensorrt_plan"
max_batch_size: 4
# default_model_filename: "ddm.engine"


dynamic_batching {
    # 1ms
    max_queue_delay_microseconds: 1000
}

input [
  {
    name: "input_0"
    data_type: TYPE_FP32
    # [C, SLIDING_WINDOWS_SIZE, H, W], where SLIDING_WINDOWS_SIZE = 2*FRAMES_PER_SIDE + SEQUENCE_BATCH.
    # Keep -1 here for generic purpose; model.py decouples the long window into sequence batches.
    dims: [3, -1, ${DS_ACTION_IN_RESOLUTION}, ${DS_ACTION_IN_RESOLUTION} ]
  }
]

output [
  {
    name: "output_0"
    data_type: TYPE_FP32
    # [N, SEQUENCE_BATCH] for the DeepStream long-window input.
    dims: [-1]
  }
]


instance_group [{
    count: 1
    kind: KIND_GPU
    gpus: 0
    }
]

parameters: { key: "FORCE_CPU_ONLY_INPUT_TENSORS" value: {string_value:"no"}}

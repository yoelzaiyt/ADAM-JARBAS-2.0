# ============================================================
# JARBAS 2.0 - Environment Configuration
# ============================================================

# ============================================================
# USADAS PELO DEPLOY REAL (api/index.js na Vercel + PWA)
# Estas 7 têm que existir de verdade no projeto Vercel (Settings >
# Environment Variables) para o chat, geração de imagem e auth
# funcionarem em produção.
# ============================================================

DEEPSEEK_API_KEY=your-deepseek-key
OPENROUTER_API_KEY=your-openrouter-key
NVIDIA_API_KEY=your-nvidia-key
HERMES_API_KEY=your-hermes-key
ZHIPUAI_API_KEY=your-zhipuai-key

# Usadas por api/index.js (requireAuth) para validar o token de sessão
# do Supabase Auth em /api/v1/chat e /api/v1/images/generate.
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Frontend (Vite, precisa do prefixo VITE_) ---
# Só precisam existir no .env local de quem roda o build do PWA
# (packages/apps/jarbas-pwa/.env) - o Vercel não builda o frontend
# (vercel.json pula install/build), o dist/ é commitado pronto.
# Mesmos valores de SUPABASE_URL/SUPABASE_ANON_KEY acima.
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ============================================================
# USADAS APENAS PELO MONOREPO NÃO CONECTADO
# (packages/services/api-gateway, packages/services/auth-service,
# packages/core/*, packages/business/*) - nada disso está no ar hoje.
# Só mexer aqui se for de fato ligar esse backend alternativo.
# ============================================================

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

DATABASE_URL=postgresql://jarbas:jarbas_dev@localhost:5432/jarbas_db
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

JWT_SECRET=generate-a-256-bit-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
API_KEY_SALT=generate-a-random-salt

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_RERANK_MODEL=llama-nemotron-rerank-vl-1b-v2
OLLAMA_BASE_URL=http://localhost:11434
OPENCODE_BASE_URL=http://localhost:4096
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
HERMES_BASE_URL=https://api.nousresearch.com/v1

MONTHLY_BUDGET_LIMIT=100.00
COST_ALERT_THRESHOLD=80
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

MEMORY_COLLECTION=jarbas_memory
MEMORY_VECTOR_SIZE=1536
TENANT_ISOLATION=true
MAX_TENANTS=100

# --- BrainAPI V2 ---
BRAINAPI_URL=http://localhost:8000
BRAINAPI_TOKEN=your-brainpat-token
BRAINAPI_BRAIN_ID=jarbas-default-brain

# --- CORS (usado pelo api-gateway do monorepo, NÃO pelo api/index.js) ---
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

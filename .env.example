# ============================================================
# JARBAS 2.0 - Environment Configuration
# ============================================================

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

DATABASE_URL=postgresql://jarbas:jarbas_dev@localhost:5432/jarbas_db
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

JWT_SECRET=generate-a-256-bit-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
API_KEY_SALT=generate-a-random-salt

# --- AI Providers ---
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

NVIDIA_API_KEY=your-nvidia-key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_RERANK_MODEL=llama-nemotron-rerank-vl-1b-v2

OLLAMA_BASE_URL=http://localhost:11434
OPENCODE_BASE_URL=http://localhost:4096

ZHIPUAI_API_KEY=your-zhipuai-key
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

HERMES_API_KEY=your-hermes-key
HERMES_BASE_URL=https://api.nousresearch.com/v1

MONTHLY_BUDGET_LIMIT=100.00
COST_ALERT_THRESHOLD=80
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

MEMORY_COLLECTION=jarbas_memory
MEMORY_VECTOR_SIZE=1536
TENANT_ISOLATION=true
MAX_TENANTS=100

# --- BrainAPI V2 ---
BRAINAPI_URL=http://localhost:8000
BRAINAPI_TOKEN=your-brainpat-token
BRAINAPI_BRAIN_ID=jarbas-default-brain

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# --- Supabase ---
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key
